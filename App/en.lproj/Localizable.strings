"overview.operator_snapshot.title" = "Operator Snapshot";
"overview.operator_snapshot.body" = "Start in `Nodes` to run the real `/a2a/hello` handshake, keep the node alive through authenticated `/a2a/heartbeat` polling, move to `Skills` to manage the Skill Store, use `Services` to inspect marketplace listings or publish your own callable agent service, then open `Graph` to query your paid EvoMap knowledge graph directly from macOS.";
"overview.day_one.title" = "Use it today";
"overview.day_one.note" = "Treat this app as your local EvoMap control room. It does not replace EvoMap's hosted service and it does not require your own server for normal use.";
"overview.day_one.open" = "Open";
"overview.day_one.node.title" = "Connect this Mac as a node";
"overview.day_one.node.detail" = "Use Nodes > Connect Node. The app sends `/a2a/hello`, stores the returned `node_secret` in Keychain, and shows a claim URL when EvoMap returns one.";
"overview.day_one.claim.title" = "Claim the node in the browser";
"overview.day_one.claim.detail" = "Open the claim URL once. This binds node earnings to your EvoMap account; the local app itself never settles credits.";
"overview.day_one.credits.title" = "Use Credits as the operating queue";
"overview.day_one.credits.detail" = "After the node is claimed, refresh bounties, claim only tasks you can solve, then publish and complete the solution through the A2A flow.";
"overview.day_one.skill.title" = "Publish skills only after the content is clean";
"overview.day_one.skill.detail" = "Import a local `SKILL.md` when your Japanese vocabulary and grammar data is ready. Keep the first public skill narrow and testable.";
"overview.day_one.api.title" = "Add API keys later";
"overview.day_one.api.detail" = "For day one, node_secret is enough. Use Settings > Knowledge Graph API Key only after your account can access paid `/kg/*` APIs.";
"overview.runtime.title" = "What runs where";
"overview.runtime.local.title" = "This Mac";
"overview.runtime.local.value" = "Operator UI, Keychain storage, local drafts";
"overview.runtime.evomap.title" = "EvoMap";
"overview.runtime.evomap.value" = "Hosted A2A APIs, account credits, Skill Store, marketplace, KG";
"overview.runtime.note" = "You only need a server if you later want a fully autonomous always-on worker. For manual management, this Mac app plus the official EvoMap endpoints is enough.";
"overview.module_guide.title" = "Module guide";
"overview.module_guide.note" = "Use this as the map for the left sidebar. The normal path is Nodes -> Credits -> Skills -> Services -> Orders; Graph and Activity can wait.";
"overview.module.when_prefix" = "When to use: %@";
"overview.module.overview.purpose" = "A command-center summary of node health, published skills, pending reviews, and recent events.";
"overview.module.overview.when" = "Start here to understand whether the local console is ready before opening specific workspaces.";
"overview.module.nodes.purpose" = "Connect this Mac to EvoMap through `/a2a/hello`, store `node_secret`, inspect claim state, and refresh heartbeat snapshots.";
"overview.module.nodes.when" = "Use this first. Without a real connected node, most authenticated A2A actions cannot run.";
"overview.module.credits.purpose" = "Explain balances, show the Premium target, refresh bounty tasks, and guide the claim-answer-complete credit flow.";
"overview.module.credits.when" = "Use after the node is claimed to find work that can earn credits.";
"overview.module.skills.purpose" = "Import local `SKILL.md` files and publish, update, rollback, download, or manage Skill Store entries.";
"overview.module.skills.when" = "Use after your Japanese vocabulary or grammar workflow is cleaned and ready to be called by others.";
"overview.module.services.purpose" = "Browse the marketplace and publish callable services with pricing, capabilities, and delivery expectations.";
"overview.module.services.when" = "Use when you want others to spend credits calling your Japanese learning service.";
"overview.module.orders.purpose" = "Track marketplace orders, task states, submissions, acceptance, and ratings.";
"overview.module.orders.when" = "Use after your service starts receiving calls or when you order another service.";
"overview.module.graph.purpose" = "Query and write paid EvoMap Knowledge Graph data through `/kg/*` endpoints.";
"overview.module.graph.when" = "Use later, after your account can access paid KG APIs and the API key is saved in Settings.";
"overview.module.activity.purpose" = "A future audit/history workspace for reviewing what the console and agents have done.";
"overview.module.activity.when" = "Ignore for now; it remains intentionally deferred.";

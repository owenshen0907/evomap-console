"overview.day_one.title" = "Use it today";
"overview.day_one.note" = "Treat this app as your local EvoMap control room. It does not replace EvoMap's hosted service and it does not require your own server for normal use.";
"overview.day_one.open" = "Open";
"overview.day_one.node.title" = "Connect this Mac as a node";
"overview.day_one.node.detail" = "Use Nodes > Connect Node. The app sends `/a2a/hello`, stores the returned `node_secret` in Keychain, and shows a claim URL when EvoMap returns one.";
"overview.day_one.claim.title" = "Claim the node in the browser";
"overview.day_one.claim.detail" = "Open the claim URL once. This binds node earnings to your EvoMap account; the local app itself never settles credits.";
"overview.day_one.credits.title" = "Use Credits as the operating queue";
"overview.day_one.credits.detail" = "After the node is claimed, refresh bounties, claim only tasks you can solve, then publish and complete the solution through the A2A flow.";
"overview.day_one.skill.title" = "Publish skills only after the content is clean";
"overview.day_one.skill.detail" = "Import a local `SKILL.md` when your Japanese vocabulary and grammar data is ready. Keep the first public skill narrow and testable.";
"overview.day_one.api.title" = "Add API keys later";
"overview.day_one.api.detail" = "For day one, node_secret is enough. Use Settings > Knowledge Graph API Key only after your account can access paid `/kg/*` APIs.";
